<UserControl x:Class="Decrypta.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,20,28,28" MaxWidth="860" HorizontalAlignment="Left">
      <TextBlock Text="Settings" Style="{StaticResource Text.Title}"/>

      <TextBlock Text="Output" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <TextBlock Text="Where decrypted IPAs are saved" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"/>
            <ui:Button Grid.Column="1" Content="Browse…" Margin="10,0,0,0" Click="OnBrowse"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="Defaults" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Default device SSH user" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="palera1n is usually root (password alpine) or mobile."/>
            </StackPanel>
            <ui:TextBox HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="180"
                        Text="{Binding SshUser, UpdateSourceTrigger=PropertyChanged}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Default storefront" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Two-letter country code used when it can't be inferred, e.g. US."/>
            </StackPanel>
            <ui:TextBox HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="180"
                        Text="{Binding Storefront, UpdateSourceTrigger=PropertyChanged}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Verbose decrypt log" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Stream the on-device helper's per-image log during a decrypt."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding Verbose}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Check for updates automatically" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="On launch, check GitHub for a newer release. Updates download only when you click Install and are SHA-256 verified before running."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding AutoUpdateCheck}"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <ui:Button Content="Save settings" Appearance="Primary" MinWidth="140"
                 HorizontalAlignment="Left" Margin="0,18,0,0" Command="{Binding SaveSettingsCommand}"/>

      <TextBlock Text="About" Style="{StaticResource Text.Section}" Margin="0,26,0,10"/>
      <ui:Card>
        <StackPanel>
          <TextBlock Style="{StaticResource Text.Body}"
                     Text="App Store binaries are wrapped in Apple FairPlay DRM whose key is bound to the Secure Enclave, so decryption must run on genuine Apple silicon. Decrypta does all orchestration on Windows and uses your connected jailbroken device (over the USB cable or Wi-Fi) as the decryption engine — no macOS, no WSL."/>
          <TextBlock Style="{StaticResource Text.Caption}" Margin="0,10,0,0"
                     Text="Built on majd/ipatool (App Store client) and londek/ipadecrypt (on-device decrypt, based on 34306/TrollDecryptJB). Use only with apps you own or have a license for."/>
        </StackPanel>
      </ui:Card>
    </StackPanel>
  </ScrollViewer>
</UserControl>

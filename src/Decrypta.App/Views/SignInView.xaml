<UserControl x:Class="Decrypta.App.Views.SignInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid Margin="28,20,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Sign in &amp; set up device" Style="{StaticResource Text.Title}"/>
      <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                 Text="Sign in with your Apple ID and the device's SSH login. When Apple sends a 6-digit code, type it into the box below and press Send."/>
    </StackPanel>

    <ui:InfoBar Grid.Row="1" Severity="Informational" IsClosable="False" IsOpen="True" Margin="0,14,0,0"
                Title="On the jailbroken device (Sileo)"
                Message="Install OpenSSH, AppSync Unified and appinst — repo https://lukezgd.github.io/repo"/>

    <ui:Card Grid.Row="2" Margin="0,14,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="28"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Apple ID email" Style="{StaticResource Text.FieldLabel}"/>
          <ui:TextBox PlaceholderText="you@example.com"
                      Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Text="Apple ID password" Style="{StaticResource Text.FieldLabel}" Margin="0,14,0,6"/>
          <ui:PasswordBox x:Name="ApplePw" PlaceholderText="password" PasswordChanged="OnApplePwChanged"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Device SSH user" Style="{StaticResource Text.FieldLabel}"/>
          <ui:TextBox Text="{Binding SshUser, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="root"/>
          <TextBlock Text="Device SSH password" Style="{StaticResource Text.FieldLabel}" Margin="0,14,0,6"/>
          <ui:PasswordBox x:Name="SshPw" PlaceholderText="alpine (palera1n default)" PasswordChanged="OnSshPwChanged"/>
        </StackPanel>
      </Grid>
    </ui:Card>

    <ui:Card Grid.Row="3" Margin="0,14,0,0" VerticalContentAlignment="Stretch" Padding="0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="14,14,14,10">
          <ui:Button Content="Sign in &amp; set up device" Appearance="Primary" MinWidth="200"
                     Command="{Binding SignInCommand}"/>
          <ui:Button Content="Reset credentials" Appearance="Transparent" Margin="10,0,0,0"
                     Command="{Binding ResetSignInCommand}"/>
          <ProgressBar Width="180" Height="4" Margin="18,0,0,0" VerticalAlignment="Center"
                       IsIndeterminate="{Binding ProgressActive}"
                       Visibility="{Binding ProgressActive, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
        <TextBox x:Name="Log" Style="{StaticResource Console}" Background="Transparent" BorderThickness="0"
                 Margin="4,0,4,4" Text="{Binding SignInLogText, Mode=OneWay}" TextChanged="OnLogChanged"/>
      </DockPanel>
    </ui:Card>

    <ui:Card Grid.Row="4" Margin="0,12,0,0" Padding="12,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding PromptHint}" Foreground="{StaticResource Brush.Fuchsia}"
                   FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" Margin="4,0,12,0"/>
        <ui:TextBox Grid.Column="1" x:Name="ConsoleInput"
                    PlaceholderText="type here when asked (e.g. the 6-digit code), then Send"
                    Text="{Binding ConsoleInput, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnInputKeyDown"/>
        <ui:Button Grid.Column="2" Content="Send" Appearance="Primary" MinWidth="90"
                   Margin="10,0,0,0" Command="{Binding SendConsoleCommand}"/>
      </Grid>
    </ui:Card>
  </Grid>
</UserControl>

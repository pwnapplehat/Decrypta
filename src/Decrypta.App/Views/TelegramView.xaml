<UserControl x:Class="Decrypta.App.Views.TelegramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid Margin="28,20,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Telegram bot" Style="{StaticResource Text.Title}"/>
      <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                 Text="Control decryption from your phone. Keep Decrypta running with a device connected, then use the bot in Telegram — list versions, decrypt, and get the IPA, without touching Windows."/>
    </StackPanel>

    <!-- Everything configurable scrolls, so nothing gets clipped on smaller windows. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" Margin="0,0,-10,0">
    <StackPanel>
    <!-- Setup -->
    <ui:Card Margin="0,16,0,0">
      <StackPanel>
        <ui:ToggleSwitch Content="Enable Telegram bot" IsChecked="{Binding TelegramEnabled}"/>

        <TextBlock Text="Bot token" Style="{StaticResource Text.FieldLabel}" Margin="0,14,0,4"/>
        <ui:TextBox PlaceholderText="e.g. 8123456789:AAE… (from @BotFather)"
                    Text="{Binding TelegramBotToken, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="0,6,0,0" TextWrapping="Wrap"
                   Text="Create a bot once: open @BotFather in Telegram → send /newbot → follow the prompts → copy the token here. The token is stored locally on this PC only."/>

        <Separator Margin="0,16,0,12" Background="{StaticResource Brush.Inset}"/>
        <TextBlock Text="Big IPAs (over 50 MB)" Style="{StaticResource Text.FieldLabel}"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,8" TextWrapping="Wrap"
                   Text="Telegram's cloud caps bot uploads at 50 MB. Choose how the bot delivers bigger apps (helper tools download automatically on first use; ports are auto-selected):"/>

        <RadioButton GroupName="bigfile" Content="Private download link (recommended — any size, no setup)"
                     IsChecked="{Binding LargeModeLink}" Margin="0,2,0,0"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="24,0,0,6" TextWrapping="Wrap"
                   Text="Sends an unguessable https link (via Cloudflare) that expires in 30 min. The file is briefly reachable at that random URL while downloading."/>

        <RadioButton GroupName="bigfile" Content="Send in-chat, up to ~2 GB (local Bot API server)"
                     IsChecked="{Binding LargeModeServer}" Margin="0,2,0,0"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="24,0,0,6" TextWrapping="Wrap"
                   Text="Auto-runs a bundled Telegram Bot API server. Needs a one-time api_id/api_hash (Telegram requires it for any such server)."/>

        <StackPanel Margin="24,0,0,6" Visibility="{Binding ShowApiCreds, Converter={StaticResource BoolToVis}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" PlaceholderText="api_id"
                        Text="{Binding TelegramApiId, UpdateSourceTrigger=PropertyChanged}"/>
            <ui:TextBox Grid.Column="1" Margin="8,0,0,0" PlaceholderText="api_hash"
                        Text="{Binding TelegramApiHash, UpdateSourceTrigger=PropertyChanged}"/>
          </Grid>
          <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,0" TextWrapping="Wrap"
                     Text="Get these free at my.telegram.org → API development tools (one-time, tied to your Telegram account)."/>
        </StackPanel>

        <RadioButton GroupName="bigfile" Content="Leave big files on the PC (report the path only)"
                     IsChecked="{Binding LargeModeOff}" Margin="0,2,0,0"/>

        <Separator Margin="0,16,0,12" Background="{StaticResource Brush.Inset}"/>
        <TextBlock Text="Running for the bot" Style="{StaticResource Text.FieldLabel}"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,8" TextWrapping="Wrap"
                   Text="While the bot is enabled, closing the window keeps Decrypta running in the system tray so the bot stays reachable (right-click the tray icon to quit). With the bot off, closing quits normally."/>
        <ui:ToggleSwitch Content="Start Decrypta with Windows (minimized, for the bot)"
                         IsChecked="{Binding LaunchOnStartup}"/>

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
          <ui:Button Content="Apply" Appearance="Primary" MinWidth="120" Command="{Binding ApplyTelegramCommand}"/>
          <Ellipse Width="9" Height="9" Margin="18,0,7,0" VerticalAlignment="Center"
                   Fill="{Binding BotRunning, Converter={StaticResource BoolToBrush}}"/>
          <TextBlock Text="{Binding TelegramStatus}" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
        </StackPanel>
      </StackPanel>
    </ui:Card>

    <!-- Pairing (shown once the bot is online) -->
    <ui:Card Margin="0,14,0,0"
             Visibility="{Binding BotRunning, Converter={StaticResource BoolToVis}}">
      <StackPanel>
        <TextBlock Text="Pair your phone" Style="{StaticResource Text.FieldLabel}"/>
        <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,10" TextWrapping="Wrap"
                   Text="Open your bot in Telegram, press Start, then send the command below. Only paired chats can control the bot."/>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource Brush.Inset}" CornerRadius="8" Padding="14,8">
            <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
              <Run Text="/pair "/><Run Text="{Binding TelegramPairCode}"/>
            </TextBlock>
          </Border>
          <ui:Button Content="Copy" Appearance="Secondary" Margin="10,0,0,0" Command="{Binding CopyPairCodeCommand}"/>
        </StackPanel>
      </StackPanel>
    </ui:Card>

    </StackPanel>
    </ScrollViewer>

    <!-- Activity log — pinned at the bottom with its own scroll. -->
    <ui:Card Grid.Row="2" Margin="0,14,0,0" Height="120" VerticalContentAlignment="Stretch" Padding="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TextBlock Text="{Binding TelegramLogText}" FontFamily="Consolas" FontSize="12"
                   TextWrapping="Wrap" Padding="8"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
      </ScrollViewer>
    </ui:Card>
  </Grid>
</UserControl>

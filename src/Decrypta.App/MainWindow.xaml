<ui:FluentWindow x:Class="Decrypta.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:Decrypta.App.Views"
                 Title="Decrypta"
                 Width="1240" Height="820" MinWidth="1000" MinHeight="660"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True"
                 TextOptions.TextFormattingMode="Display"
                 UseLayoutRounding="True"
                 FontFamily="Segoe UI Variable Text, Segoe UI">

  <Grid>
    <!-- A whisper-thin tint over Mica keeps card/text contrast on bright wallpapers;
         far lighter than an acrylic smoke tint because Mica is already mostly opaque.
         Shown only when the Mica backdrop actually applied (see OnSourceInitialized). -->
    <Border x:Name="MicaTint" Background="#140A0A0F" Visibility="Collapsed"/>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ══════════ Title bar ══════════ -->
      <ui:TitleBar Grid.Row="0">
        <ui:TitleBar.Header>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
            <Image Source="pack://application:,,,/Assets/icon.png" Width="22" Height="22"
                   VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Decrypta" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
          </StackPanel>
        </ui:TitleBar.Header>
      </ui:TitleBar>

      <!-- ══════════ Device selector strip ══════════ -->
      <Grid Grid.Row="1" Margin="16,2,16,8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
          <TextBlock Text="Device" Style="{StaticResource Text.Section}" VerticalAlignment="Center"
                     Margin="0,0,10,0"/>
          <ComboBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                    MinWidth="320" MaxWidth="420" FontSize="12">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayLine}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <ui:Button Appearance="Transparent" Margin="6,0,0,0"
                     Command="{Binding RefreshDevicesCommand}" ToolTip="Rescan devices">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="ArrowSync24"/>
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
        <Border HorizontalAlignment="Right" VerticalAlignment="Center">
          <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource Badge}">
              <Setter Property="Background" Value="#2B1620"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ServiceUp}" Value="True">
                  <Setter Property="Background" Value="#12241C"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{StaticResource Brush.Danger}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ServiceUp}" Value="True">
                      <Setter Property="Fill" Value="{StaticResource Brush.Success}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding DeviceStatus}" FontSize="11.5" FontWeight="SemiBold"
                       Margin="7,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ══════════ Update banner ══════════ -->
      <Grid Grid.Row="2" Margin="16,0,16,8"
            Visibility="{Binding UpdateBannerVisible, Converter={StaticResource BoolToVis}}">
        <ui:InfoBar Severity="Informational" IsClosable="False" IsOpen="True"
                    Title="Update available" Message="{Binding UpdateBannerText}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,12,0">
          <ui:Button Content="What's new" Appearance="Transparent" Command="{Binding ViewUpdateCommand}" Margin="0,0,8,0"/>
          <ui:Button Content="Install update" Appearance="Primary" Command="{Binding InstallUpdateCommand}"
                     Margin="0,0,8,0" Visibility="{Binding UpdateCanAutoInstall, Converter={StaticResource BoolToVis}}"/>
          <ui:Button Content="Later" Appearance="Transparent" Command="{Binding DismissUpdateCommand}"/>
        </StackPanel>
      </Grid>

      <!-- ══════════ Navigation + pages ══════════ -->
      <ui:NavigationView x:Name="RootNavigation" Grid.Row="3"
                         PaneDisplayMode="Left"
                         OpenPaneLength="216"
                         IsBackButtonVisible="Collapsed"
                         IsPaneToggleVisible="False"
                         Transition="FadeInWithSlide">
        <ui:NavigationView.MenuItems>
          <ui:NavigationViewItem Content="Decrypt" TargetPageType="{x:Type views:DecryptView}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="LockOpen24"/>
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Sign in" TargetPageType="{x:Type views:SignInView}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Key24"/>
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Library" TargetPageType="{x:Type views:LibraryView}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Apps24"/>
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>
        <ui:NavigationView.FooterMenuItems>
          <ui:NavigationViewItem Content="Doctor" TargetPageType="{x:Type views:DoctorView}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Stethoscope24"/>
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Settings" TargetPageType="{x:Type views:SettingsView}">
            <ui:NavigationViewItem.Icon>
              <ui:SymbolIcon Symbol="Settings24"/>
            </ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.FooterMenuItems>
      </ui:NavigationView>

      <!-- ══════════ Status bar ══════════ -->
      <Border Grid.Row="4" Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0" Padding="16,6">
        <Grid>
          <TextBlock Text="{Binding Status}" FontSize="12"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          <TextBlock HorizontalAlignment="Right" FontSize="12"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center">
            <Run Text="{Binding SignedInSummary, Mode=OneWay}"/>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</ui:FluentWindow>

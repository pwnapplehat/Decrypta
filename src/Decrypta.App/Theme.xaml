<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

  <!-- ======================================================================
       DECRYPTA BRAND LAYER
       Fluent controls, spacing and materials come from WPF-UI (Mica backdrop,
       NavigationView, buttons, cards, toggles, inputs). This dictionary only
       carries the brand palette, typography helpers and a few bespoke pieces —
       so the Mica backdrop shows through natively.
       ====================================================================== -->

  <!-- Palette (violet → fuchsia brand on a deep surface) -->
  <Color x:Key="Color.Bg">#0A0A0F</Color>
  <Color x:Key="Color.Inset">#120E1C</Color>
  <Color x:Key="Color.Text">#ECECF3</Color>
  <Color x:Key="Color.TextSecondary">#A2A2B6</Color>
  <Color x:Key="Color.TextTertiary">#6B6B80</Color>
  <Color x:Key="Color.Accent">#8B5CF6</Color>
  <Color x:Key="Color.AccentDeep">#6D28D9</Color>
  <Color x:Key="Color.AccentSoft">#241C42</Color>
  <Color x:Key="Color.Fuchsia">#E879F9</Color>
  <Color x:Key="Color.Success">#34D399</Color>
  <Color x:Key="Color.Warning">#FBBF24</Color>
  <Color x:Key="Color.Danger">#FB7185</Color>

  <SolidColorBrush x:Key="Brush.Bg" Color="{StaticResource Color.Bg}"/>
  <SolidColorBrush x:Key="Brush.Inset" Color="{StaticResource Color.Inset}"/>
  <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}"/>
  <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
  <SolidColorBrush x:Key="Brush.TextTertiary" Color="{StaticResource Color.TextTertiary}"/>
  <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
  <SolidColorBrush x:Key="Brush.AccentDeep" Color="{StaticResource Color.AccentDeep}"/>
  <SolidColorBrush x:Key="Brush.AccentSoft" Color="{StaticResource Color.AccentSoft}"/>
  <SolidColorBrush x:Key="Brush.Fuchsia" Color="{StaticResource Color.Fuchsia}"/>
  <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
  <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
  <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>

  <LinearGradientBrush x:Key="Brush.BrandGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#8B5CF6" Offset="0"/>
    <GradientStop Color="#E879F9" Offset="1"/>
  </LinearGradientBrush>

  <FontFamily x:Key="Font.Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
  <FontFamily x:Key="Font.Display">Segoe UI Variable Display, Segoe UI</FontFamily>
  <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>

  <!-- Typography helpers -->
  <Style x:Key="Text.Title" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
    <Setter Property="FontSize" Value="24"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
  </Style>

  <Style x:Key="Text.Subtitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="Text.Section" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
    <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
  </Style>

  <Style x:Key="Text.Body" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="Text.Caption" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="Text.FieldLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
  </Style>

  <!-- Accent CTA card (brand moment) -->
  <Style x:Key="Card.Accent" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentDeep}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="16"/>
  </Style>

  <!-- Badge / pill -->
  <Style x:Key="Badge" TargetType="Border">
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="10,3"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <!-- Monospace read-only console for streamed tool output / logs -->
  <Style x:Key="Console" TargetType="TextBox">
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    <Setter Property="Background" Value="{StaticResource Brush.Inset}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
    <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Padding" Value="12,10"/>
    <Setter Property="IsReadOnly" Value="True"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1" CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
